+
+    def supported_market_types(self) -> list:
+        out = set()
+        for s in self._strategies:
+            out.update(getattr(s, "supported_market_types", ()) or ())
+        return sorted(out)
+
+    def resolve_detailed(self, snapshot) -> dict:
+        """Diagnostic structure de la resolution (ne remplace pas resolve():
+        meme logique, sortie enrichie pour les logs et les traces)."""
+        matches = [s for s in self._strategies if s.supports(snapshot)]
+        names = [getattr(s, "name", s.__class__.__name__)
+                 for s in self._strategies]
+        mnames = [getattr(s, "name", s.__class__.__name__) for s in matches]
+        code = None
+        if not matches:
+            code = "no_compatible_strategy"
+        elif len(matches) > 1:
+            code = "ambiguous_strategy_match"
+        return {
+            "market_ticker": getattr(snapshot, "ticker", None),
+            "market_type": getattr(snapshot, "market_type", None),
+            "category": getattr(snapshot, "category", None),
+            "series_ticker": getattr(snapshot, "series_ticker", None),
+            "registered_strategies": names,
+            "registered_series": self.supported_series(),
+            "registered_market_types": self.supported_market_types(),
+            "compatible_strategies": mnames,
+            "selected_strategy": mnames[0] if len(matches) == 1 else None,
+            "rejection_code": code,
+        }
