+    def _reject_cached(self, ticker, now_epoch):
+        ent = self._reject_cache.get(ticker)
+        if not ent:
+            return None
+        reason, exp = ent
+        if now_epoch >= exp:
+            del self._reject_cache[ticker]
+            return None
+        return reason
