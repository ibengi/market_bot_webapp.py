# ── Kalshi Alpha Engine — variables d'environnement (AUCUN SECRET ICI) ──
# Identifiants (obligatoires selon l'environnement)
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY=            # PEM ; \n acceptes sur une ligne
KALSHI_DEMO_KEY_ID=            # OBLIGATOIRE en --demo
KALSHI_DEMO_PRIVATE_KEY=       # OBLIGATOIRE en --demo
# Production : DOUBLE confirmation exigee
KALSHI_ENV_CONFIRM=            # LIVE pour autoriser la prod
LIVE_TRADING_CONFIRMED=        # YES pour autoriser la prod
# Modes
SHADOW_MODE=0                  # 1 = decisions completes, aucun ordre
KILL_SWITCH=0                  # 1 = coupe tout ordre immediatement
ALLOW_FALLBACK_CAPITAL=0       # demo uniquement : capital de secours si solde indisponible
CAPITAL=500                    # PLAFOND ; min(plafond, solde broker) est utilise
# Portes edge/EV
MIN_MODEL_CONFIDENCE=6
MIN_GROSS_EDGE=0.05
MIN_NET_EDGE=0.03
MIN_NET_EV=0.02
MAX_ACCEPTABLE_SPREAD=4
MIN_MARKET_SCORE=50
MIN_FILL_PROXY=40
SLIPPAGE_BUFFER_CENTS=1
# Risque
MAX_DAILY_LOSS=50
MAX_TRADES_CYCLE=3
MAX_POSITION_PCT=1.0
RISK_BUDGET_PCT=5.0
MAX_OPEN_POSITIONS=5
MAX_CATEGORY_RISK_PCT=3.0
MAX_SINGLE_MARKET_RISK_PCT=1.0
MAX_EQUITY_DRAWDOWN_PCT=20
# Scanner / Ranker
SCANNER_MIN_MINUTES=5
SCANNER_MAX_SPREAD_CENTS=10
RANKER_MIN_SCORE=40
RANKER_TOP_N=50
RANKER_HISTORY_WINDOW=30
RANKER_MIN_BOOK_OBSERVATIONS=5
RANKER_MAX_SPREAD=6
RANKER_MIN_FILL_PROBABILITY=0.30
# Infra
DATA_DIR=.                     # volume Railway persistant recommande
KALSHI_FEE_RATE_TRADING=0.07   # fallback local uniquement
LOG_LEVEL=INFO
# ── Phase modele BTC 15m ──
DEMO_TRADING=0                 # 1 = equivalent --demo
LIVE_TRADING=0                 # 1 requis pour la prod (interdit par defaut)
MODEL_APPROVED_FOR_LIVE=       # YES requis en prod (+ gatekeeper)
MODEL_CALIBRATION_FILE=model_calibration.json
SHADOW_STORE_FILE=shadow_predictions.json
GATE_MIN_PREDICTIONS=300
GATE_MIN_TRADES=100
GATE_MAX_REPORT_AGE_H=168
GATE_MAX_DRAWDOWN=10.0
GATE_MAX_ECE=0.10
